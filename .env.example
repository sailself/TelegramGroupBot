## Required
BOT_TOKEN=
GEMINI_API_KEY=

## Database
DATABASE_URL=sqlite:///bot.db
DB_MAX_CONNECTIONS=5
DB_QUEUE_CAPACITY=2048
DB_WRITE_BATCH_SIZE=32
DB_WRITE_FLUSH_MS=25

## Telegram runtime
HEAVY_COMMAND_MAX_CONCURRENCY=2
RATE_LIMIT_SECONDS=15
MODEL_SELECTION_TIMEOUT=30
DEFAULT_Q_MODEL=gemini
TELEGRAM_MAX_LENGTH=4000
USER_HISTORY_MESSAGE_COUNT=200
LOG_LEVEL=info
PUBLISH_BOT_COMMANDS=false
MEDIA_GROUP_MAX_ITEMS=256
MAX_TOOL_CONTEXT_ITEMS=10
ENABLE_TLDR_INFOGRAPHIC=false

## Access control
WHITELIST_FILE_PATH=allowed_chat.txt
ACCESS_CONTROLLED_COMMANDS=/tldr,/factcheck,/profileme,/mysong

## Gemini settings
ENABLE_GEMINI=true
GEMINI_MODEL=gemini-2.0-flash
GEMINI_LITE_MODEL=gemini-2.0-flash-lite
GEMINI_PRO_MODEL=gemini-2.5-pro-exp-03-25
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_MUSIC_MODEL=lyria-3-pro-preview
GEMINI_VIDEO_MODEL=veo-3.1-generate-preview
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_K=40
GEMINI_TOP_P=0.95
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_THINKING_LEVEL=high
GEMINI_SAFETY_SETTINGS=permissive
GEMINI_REQUEST_TIMEOUT_SECS=90
GEMINI_IMAGE_REQUEST_TIMEOUT_SECS=300

## Shared third-party model catalog
THIRD_PARTY_MODELS_CONFIG_PATH=third_party_models.json

## OpenRouter (optional)
ENABLE_OPENROUTER=true
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_ALPHA_BASE_URL=https://openrouter.ai/api/alpha
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_TOP_K=40
OPENROUTER_TOP_P=0.95
OPENROUTER_REQUEST_TIMEOUT_SECS=60

## NVIDIA hosted models (optional)
ENABLE_NVIDIA=true
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_TEMPERATURE=0.7
NVIDIA_TOP_K=40
NVIDIA_TOP_P=0.95
NVIDIA_REQUEST_TIMEOUT_SECS=60

## Ollama Cloud (optional)
ENABLE_OLLAMA=true
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.95
OLLAMA_REQUEST_TIMEOUT_SECS=60

## OpenAI Responses (optional)
ENABLE_OPENAI=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REQUEST_TIMEOUT_SECS=60

## OpenAI Codex via ChatGPT (optional)
ENABLE_OPENAI_CODEX=true
OPENAI_CODEX_BASE_URL=https://chatgpt.com/backend-api/codex
OPENAI_CODEX_ORIGINATOR=codex_cli_rs
OPENAI_CODEX_CLIENT_VERSION=0.99.0
OPENAI_CODEX_WEB_SEARCH_MODE=live
OPENAI_CODEX_WEB_SEARCH_CONTEXT_SIZE=
OPENAI_CODEX_WEB_SEARCH_ALLOWED_DOMAINS=
OPENAI_CODEX_AUTH_PATH=data/openai_codex_auth.json
OPENAI_CODEX_MODEL_PATH=data/openai_codex_model.json
OPENAI_CODEX_REQUEST_TIMEOUT_SECS=300
OPENAI_CODEX_IMAGE_RESPONSES_MODEL=gpt-5.5
OPENAI_CODEX_IMAGE_MODEL=gpt-image-2

## Search and retrieval (optional)
ENABLE_BRAVE_SEARCH=true
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_ENDPOINT=https://api.search.brave.com/res/v1/web/search
ENABLE_EXA_SEARCH=true
EXA_API_KEY=
EXA_SEARCH_ENDPOINT=https://api.exa.ai/search
ENABLE_JINA_MCP=false
JINA_AI_API_KEY=
JINA_SEARCH_ENDPOINT=https://s.jina.ai/search
JINA_READER_ENDPOINT=https://r.jina.ai/
WEB_SEARCH_PROVIDERS=brave,exa,jina
WEB_SEARCH_CACHE_TTL_SECONDS=900
WEB_SEARCH_CACHE_MAX_ENTRIES=256
EXTERNAL_ENRICH_FANOUT=4
GEMINI_UPLOAD_FANOUT=3

## Hosting and publishing (optional)
TELEGRAPH_ACCESS_TOKEN=
TELEGRAPH_AUTHOR_NAME=
TELEGRAPH_AUTHOR_URL=
CWD_PW_API_KEY=

## Support message
SUPPORT_MESSAGE=Thanks for supporting the bot! Tap the button below to open the support page.
SUPPORT_LINK=
